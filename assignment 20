4. Add Skill (Array using prev + spread)

export function AddSkillPrev() {
  const [skills, setSkills] = useState(["HTML", "CSS"]);

  return (
    <>
      <ul>
        {skills.map((s, i) => <li key={i}>{s}</li>)}
      </ul>

      <button onClick={() => setSkills(prev => [...prev, "JavaScript"])}>
        Add Skill
      </button>
    </>
  );
}


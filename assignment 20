5. Update Age (Object using prev)

export function UpdateAgePrev() {
  const [user, setUser] = useState({ name: "Kishore", age: 20 });

  return (
    <>
      <p>{user.name} - {user.age}</p>

      <button
        onClick={() =>
          setUser(prev => ({
            ...prev,
            age: prev.age + 1
          }))
        }
      >
        Increase Age
      </button>
    </>
  );
}

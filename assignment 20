2. Increase Twice (using prev)

export function IncreaseTwice() {
  const [count, setCount] = useState(0);

  const handleClick = () => {
    setCount(prev => prev + 1);
    setCount(prev => prev + 1); // correctly updates to +2
  };

  return (
    <>
      <h3>{count}</h3>
      <button onClick={handleClick}>Increase Twice</button>
    </>
  );
}


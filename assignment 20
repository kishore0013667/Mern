1. Counter (Increase / Decrease using prev)

import { useState } from "react";

export function CounterPrev() {
  const [count, setCount] = useState(0);

  return (
    <>
      <h3>{count}</h3>

      <button onClick={() => setCount(prev => prev + 1)}>
        Increase
      </button>

      <button onClick={() => setCount(prev => prev - 1)}>
        Decrease
      </button>
    </>
  );
}


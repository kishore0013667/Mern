3. Toggle Show / Hide (using prev)

export function ToggleText() {
  const [show, setShow] = useState(true);

  return (
    <>
      <button onClick={() => setShow(prev => !prev)}>
        Toggle
      </button>

      {show && <p>This is visible text</p>}
    </>
  );
}


task 3

Update User Name (Object)

import { useState } from "react";

function User() {
  const [user, setUser] = useState({
    name: "John",
    age: 25,
  });

  const updateName = () => {
    setUser({
      ...user,
      name: "Sudhan",
    });
  };

  return (
    <div>
      <h2>Name: {user.name}</h2>
      <h3>Age: {user.age}</h3>

      <button onClick={updateName}>Update Name</button>
    </div>
  );
}

export default User;


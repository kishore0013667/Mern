task 2

Toggle Status (Boolean)

import { useState } from "react";

function Status() {
  const [isOnline, setIsOnline] = useState(true);

  return (
    <div>
      <h2>{isOnline ? "Online" : "Offline"}</h2>

      <button onClick={() => setIsOnline(!isOnline)}>
        Toggle Status
      </button>
    </div>
  );
}

export default Status;


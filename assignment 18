task 4

Update Age (Object)

import { useState } from "react";

function Person() {
  const [person, setPerson] = useState({
    name: "Ravi",
    age: 22,
    city: "Chennai",
  });

  const increaseAge = () => {
    setPerson({
      ...person,
      age: person.age + 1,
    });
  };

  return (
    <div>
      <h2>{person.name}</h2>
      <p>Age: {person.age}</p>
      <p>City: {person.city}</p>

      <button onClick={increaseAge}>Increase Age</button>
    </div>
  );
}

export default Person;

